{
  "manifest_version": 3,
  "name": "Markdown Work Log",
  "version": "1.1.1",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["sidePanel", "storage", "unlimitedStorage", "downloads"],
  "side_panel": { "default_path": "index.html" },
  "action": {
    "default_title": "ログを開く",
    "default_icon": "icon-128.png"
  }
}
